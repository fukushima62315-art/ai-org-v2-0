# .env.example
# v2.0 組織設計の環境変数テンプレート
# .env にコピーして、実際の値に置き換えてください

# ===== Claude API =====
ANTHROPIC_API_KEY=your-api-key-here
CLAUDE_MODEL=claude-opus-4-6

# ===== Budget Management =====
MONTHLY_BUDGET_JPY=3000
WARNING_THRESHOLD_PERCENT=50
CAUTION_THRESHOLD_PERCENT=70
EMERGENCY_THRESHOLD_PERCENT=80

# ===== Agent Budget Allocation =====
STRATEGIST_BUDGET=800
BUILDER_BUDGET=1500
OPERATOR_BUDGET=500
RESERVE_BUDGET=200

# ===== LINE Notification =====
# LINE Developers でチャンネルを作成し、以下を設定
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-token
LINE_USER_ID=your-line-user-id

# ===== Logging =====
LOG_LEVEL=INFO
AUDIT_LOG_PATH=src/logs/audit.log
BUDGET_LOG_PATH=src/logs/budget.log
